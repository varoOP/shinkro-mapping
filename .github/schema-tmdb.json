{
    "$id": "https://github.com/varoOP/shinkro-mapping/blob/main/.github/schema-tmdb.json",
    "title": "shinkro tmdb-mal custom mapping schema",
    "type": "object",
    "default": {},
    "additionalProperties": false,
    "required": [
        "animeMovies"
    ],
    "properties": {
        "animeMovies": {
            "type": "array",
            "default": [],
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                    "mainTitle",
                    "tmdbid",
                    "malid"
                ],
                "properties": {
                    "mainTitle": {
                        "type": "string",
                        "minLength": 1,
                        "examples": [
                            "Tokyo Godfathers",
                            "Ramayana: The Legend of Prince",
                            "Bakemono no Ko"
                        ]
                    },
                    "tmdbid": {
                        "type": "integer",
                        "minimum": 0
                    },
                    "malid": {
                        "type": "integer",
                        "minimum": 1
                    }
                }
            }
        }
    }
}
