{
    "$id": "https://github.com/varoOP/shinkro-mapping/blob/main/.github/schema-tvdb.json",
    "title": "shinkro tvdb-mal custom mapping schema",
    "default": {},
    "type": "object",
    "additionalProperties": false,
    "required": [
        "AnimeMap"
    ],
    "properties": {
        "AnimeMap": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "malid": {
                        "type": "integer",
                        "minimum": 1
                    },
                    "title": {
                        "type": "string",
                        "minLength": 1
                    },
                    "type": {
                        "type": "string",
                        "enum": ["tv", "movie", "ova", "ona", "music", "special", "tv_special", "cm", "pv", "unknown"]
                    },
                    "tvdbid": {
                        "type": "integer"
                    },
                    "tvdbseason": {
                        "type": "integer"
                    },
                    "start": {
                        "type": "integer"
                    },
                    "useMapping": {
                        "type": "boolean"
                    },
                    "animeMapping": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "additionalProperties": false,
                            "properties": {
                                "tvdbseason": {
                                    "type": "integer"
                                },
                                "start": {
                                    "type": "integer"
                                },
                                "mappingType": {
                                    "type": "string",
                                    "enum": ["explicit", "range"],
                                    "default": "range"
                                },
                                "explicitEpisodes": {
                                    "type": "object",
                                    "additionalProperties": {
                                        "type": "integer",
                                        "minimum": 1
                                    },
                                    "description": "Map of TVDB episode number to MAL episode number (tvdbEp -> malEp). Only valid when mappingType is 'explicit'."
                                },
                                "skipMalEpisodes": {
                                    "type": "array",
                                    "items": {
                                        "type": "integer",
                                        "minimum": 1
                                    },
                                    "description": "List of MAL episode numbers to skip when using range mapping. Only valid when mappingType is 'range' or omitted."
                                }
                            },
                            "required": [
                                "tvdbseason",
                                "start"
                            ],
                            "allOf": [
                                {
                                    "if": {
                                        "properties": {
                                            "mappingType": { "const": "explicit" }
                                        },
                                        "required": ["mappingType"]
                                    },
                                    "then": {
                                        "required": ["explicitEpisodes"],
                                        "not": {
                                            "required": ["skipMalEpisodes"]
                                        }
                                    }
                                },
                                {
                                    "if": {
                                        "properties": {
                                            "mappingType": { "const": "range" }
                                        },
                                        "required": ["mappingType"]
                                    },
                                    "then": {
                                        "not": {
                                            "required": ["explicitEpisodes"]
                                        }
                                    }
                                }
                            ]
                        }
                    }
                },
                "required": [
                    "malid",
                    "title",
                    "type",
                    "tvdbid",
                    "tvdbseason",
                    "start",
                    "useMapping",
                    "animeMapping"
                ]
            }
        }
    }
}
